{
    "app-id": "org.classisland.ClassIsland",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "24.08",
    "sdk": "org.freedesktop.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.dotnet8",
        "org.freedesktop.Sdk.Extension.dotnet9"
    ],
    "command": "ClassIsland.Desktop",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=wayland",
        "--socket=x11",
        "--device=dri",
        "--filesystem=home",
        "--filesystem=xdg-config:ro",
        "--filesystem=xdg-data:ro",
        "--filesystem=xdg-cache:ro"
        ],
    "build-options": {
        "append-path": "/usr/lib/sdk/dotnet8/bin",
        "append-path": "/usr/lib/sdk/dotnet9/bin",
        "env": {
            "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
            "DOTNET_NO_MANIFEST_UPDATE": "1",
            "RESOLV_CONF": "/etc/resolv.conf"
        }
    },
    "modules": [
        {
            "name": "ClassIsland",
            "buildsystem": "simple",
            "build-commands": [
                "dotnet publish -c Release --source nuget-sources -o /app/bin ClassIsland.Desktop/ClassIsland.Desktop.csproj",
                "mkdir -p /app/share/applications",
                "mkdir -p /app/share/icons/hicolor/scalable/apps",
                "mkdir -p /app/share/icons/hicolor/128x128/apps",
                "mkdir -p /app/share/icons/hicolor/512x512/apps",
                "cp ClassIsland/Assets/ShortcutTemplates/cn.classisland.app.desktop /app/share/applications/org.classisland.ClassIsland.desktop",
                "sed -i 's|{1}|/app/bin/ClassIsland.Desktop|g' /app/share/applications/org.classisland.ClassIsland.desktop",
                "sed -i 's/Icon=classisland/Icon=org.classisland.ClassIsland/g' /app/share/applications/org.classisland.ClassIsland.desktop",
                "cp ClassIsland/Assets/AppLogo.png /app/share/icons/hicolor/512x512/apps/org.classisland.ClassIsland.png",
                "cp ClassIsland/Assets/AppLogo@128w.png /app/share/icons/hicolor/128x128/apps/org.classisland.ClassIsland.png",
                "cp ClassIsland/Assets/AppLogo_AppLogo.svg /app/share/icons/hicolor/scalable/apps/org.classisland.ClassIsland.svg"
                ],
            "sources": [
                {
                    "type": "dir",
                    "path": "../..",
                    "dest": "."
                },
                "sources.json"
            ]
        }
    ]
}
