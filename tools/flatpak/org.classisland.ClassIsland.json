{
    "app-id": "org.classisland.ClassIsland",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "24.08",
    "sdk": "org.freedesktop.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.dotnet8",
        "org.freedesktop.Sdk.Extension.dotnet9"
    ],
    "command": "run.sh",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=wayland",
        "--socket=x11",
        "--socket=session-bus",
        "--device=dri",
        "--filesystem=home",
        "--filesystem=xdg-config:ro",
        "--filesystem=xdg-data:ro",
        "--filesystem=xdg-cache:ro"
        ],
    "build-options": {
        "append-path": "/usr/lib/sdk/dotnet8/bin",
        "append-path": "/usr/lib/sdk/dotnet9/bin",
        "append-ld-library-path": "/usr/lib/sdk/dotnet9/lib",
        "prepend-pkg-config-path": "/usr/lib/sdk/dotnet9/lib/pkgconfig",
        "env": {
            "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
            "DOTNET_NO_MANIFEST_UPDATE": "1",
            "RESOLV_CONF": "/etc/resolv.conf"
        },
        "arch": {
        "aarch64": {
            "env" : {
                "RUNTIME": "linux-arm64"
            }
        },
        "x86_64": {
            "env" : {
                "RUNTIME": "linux-x64"
            }
        }
    }
    },
    "modules": [
        {
            "name": "ClassIsland",
            "buildsystem": "simple",
            "build-commands": [
                "dotnet publish -c Release --source nuget-sources --source /usr/lib/sdk/dotnet8/nuget/packages --source /usr/lib/sdk/dotnet9/nuget/packages -o /app/bin ClassIsland.Desktop/ClassIsland.Desktop.csproj --runtime $RUNTIME --sc",
                "mkdir -p /app/share/applications",
                "mkdir -p /app/share/icons/hicolor/512x512/apps",
                "echo flatpak>>/app/bin/PackageType",
                "install -Dm755 run.sh /app/bin/run.sh"
                ],
            "sources": [
                {
                    "type": "dir",
                    "path": "../..",
                    "dest": "."
                },
                "sources.json",
                {
                    "type": "file",
                    "path": "run.sh",
                    "dest-filename": "run.sh"
                }
            ]
        }
    ]
}
