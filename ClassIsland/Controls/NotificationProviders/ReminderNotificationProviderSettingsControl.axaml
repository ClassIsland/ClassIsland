<ci:NotificationProviderControlBase
    x:TypeArguments="notificationProviderSettings:ReminderNotificationProviderSettings"
    x:Class="ClassIsland.Controls.NotificationProviders.ReminderNotificationProviderSettingsControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ClassIsland.Controls.NotificationProviders"
    xmlns:controls1="clr-namespace:ClassIsland.Core.Controls;assembly=ClassIsland.Core"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:notificationProviderSettings="clr-namespace:ClassIsland.Models.NotificationProviderSettings"
    xmlns:controls2="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer
        DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:ReminderNotificationProviderSettingsControl}}">
        <StackPanel Classes="settings-container animated-intro" Margin="0">

            <!-- 启用日程提醒 -->
            <controls2:SettingsExpander IconSource="{ci:FluentIconSource &#xe8bd;}"
                                       Header="启用日程提醒"
                                       Description="在设定的日程时间发出醒目提醒。"
                                       IsExpanded="{Binding Settings.IsEnabled, Mode=OneWay}">
                <controls2:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Settings.IsEnabled}"/>
                </controls2:SettingsExpander.Footer>

                <!-- 检查间隔 -->
                <controls2:SettingsExpanderItem IconSource="{ci:FluentIconSource &#xe02b;}"
                                                Content="提醒检查间隔"
                                                Description="两次检查日程提醒的间隔">
                    <controls2:SettingsExpanderItem.Footer>
                        <controls1:Field Suffix="秒">
                            <controls2:NumberBox Maximum="600" Minimum="5"
                                                 Value="{Binding Settings.CheckIntervalSeconds}"
                                                 Width="150"
                                                 SpinButtonPlacementMode="Inline"/>
                        </controls1:Field>
                    </controls2:SettingsExpanderItem.Footer>
                </controls2:SettingsExpanderItem>
            </controls2:SettingsExpander>

        </StackPanel>
    </ScrollViewer>
</ci:NotificationProviderControlBase>
