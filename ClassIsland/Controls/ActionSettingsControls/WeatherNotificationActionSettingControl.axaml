<ci:ActionSettingsControlBase x:Class="ClassIsland.Controls.ActionSettingsControls.WeatherNotificationActionSettingControl"
                              x:TypeArguments="actionSettings:WeatherNotificationActionSettings"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ClassIsland.Controls.ActionSettingsControls"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
                          xmlns:actionSettings="clr-namespace:ClassIsland.Models.ActionSettings"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:WeatherNotificationActionSettingControl}}">
        <ComboBox SelectedIndex="{Binding Settings.NotificationKind}">
            <ComboBoxItem>三天天气预报</ComboBoxItem>
            <ComboBoxItem>气象预警</ComboBoxItem>
            <ComboBoxItem>逐小时天气预报</ComboBoxItem>
        </ComboBox>
    </Grid>
</ci:ActionSettingsControlBase>
