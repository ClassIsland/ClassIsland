<controls:ComponentBase x:TypeArguments="componentSettings:ReminderTimelineComponentSettings" 
                         x:Class="ClassIsland.Controls.Components.ReminderTimelineComponentSettingsControl"
                         xmlns="https://github.com/avaloniaui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:local="clr-namespace:ClassIsland.Controls.Components"
                         xmlns:controls="clr-namespace:ClassIsland.Core.Abstractions.Controls;assembly=ClassIsland.Core"
                         xmlns:componentSettings="clr-namespace:ClassIsland.Models.ComponentSettings"
                         xmlns:ci="http://classisland.tech/schemas/xaml/core"
                         xmlns:controls2="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
                         mc:Ignorable="d"
                         d:DesignHeight="450"
                         d:DesignWidth="800">
    <ScrollViewer DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:ReminderTimelineComponentSettingsControl}}">
        <StackPanel Classes="component-settings-container animated-intro">
            <controls2:SettingsExpander IconSource="{ci:FluentIconSource &#xE916;}"
                                        Header="过去最多显示几个分组"
                                        Description="当前时间之前（已过期）最多显示多少个分组。同一分钟的所有日程算一个分组。超出部分整个隐藏。">
                <controls2:SettingsExpander.Footer>
                    <NumericUpDown Minimum="1" Maximum="30"
                                   Value="{Binding Settings.GroupsBefore, Mode=TwoWay}"
                                   FormatString="N0" Increment="1"
                                   MinWidth="120" HorizontalAlignment="Right"/>
                </controls2:SettingsExpander.Footer>
            </controls2:SettingsExpander>

            <controls2:SettingsExpander IconSource="{ci:FluentIconSource &#xE916;}"
                                        Header="未来最多显示几个分组"
                                        Description="当前时间之后（未过期）最多显示多少个分组。同一分钟的所有日程算一个分组。超出部分整个隐藏。">
                <controls2:SettingsExpander.Footer>
                    <NumericUpDown Minimum="1" Maximum="30"
                                   Value="{Binding Settings.GroupsAfter, Mode=TwoWay}"
                                   FormatString="N0" Increment="1"
                                   MinWidth="120" HorizontalAlignment="Right"/>
                </controls2:SettingsExpander.Footer>
            </controls2:SettingsExpander>

            <controls2:SettingsExpander IconSource="{ci:FluentIconSource &#xE8A1;}"
                                        Header="每个分组最多显示几个"
                                        Description="同一分钟有多个日程时，超出此数量的日程合并显示为「等N」胶囊。">
                <controls2:SettingsExpander.Footer>
                    <NumericUpDown Minimum="1" Maximum="20"
                                   Value="{Binding Settings.MaxPerGroup, Mode=TwoWay}"
                                   FormatString="N0" Increment="1"
                                   MinWidth="120" HorizontalAlignment="Right"/>
                </controls2:SettingsExpander.Footer>
            </controls2:SettingsExpander>
        </StackPanel>
    </ScrollViewer>
</controls:ComponentBase>
