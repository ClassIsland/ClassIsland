<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             xmlns:models="clr-namespace:ClassIsland.Shared.Models.Profile;assembly=ClassIsland.Shared"
             xmlns:automation="clr-namespace:ClassIsland.Core.Controls.Automation;assembly=ClassIsland.Core"
             x:Class="ClassIsland.Controls.ReminderEditorControl">
  <StackPanel Spacing="8" Margin="8">
    <ci:Field Label="标题">
      <TextBox x:Name="TitleBox" />
    </ci:Field>
    <ci:Field Label="消息（可选）">
      <TextBox x:Name="MessageBox" AcceptsReturn="True" Height="80" Watermark="输入提醒消息内容…"/>
    </ci:Field>
    <StackPanel Orientation="Horizontal" Spacing="12">
      <ci:Field Label="启用" Margin="0 0 0 0">
        <ToggleSwitch x:Name="EnabledSwitch"
                      OnContent="开" OffContent="关"
                      HorizontalAlignment="Left" />
      </ci:Field>
    </StackPanel>

    <ci:Field Label="重复">
      <ComboBox x:Name="FrequencyCombo" SelectedIndex="0">
        <ComboBoxItem Tag="Once">单次</ComboBoxItem>
        <ComboBoxItem Tag="Daily">每天</ComboBoxItem>
        <ComboBoxItem Tag="Weekly">每周</ComboBoxItem>
        <ComboBoxItem Tag="Yearly">每年</ComboBoxItem>
      </ComboBox>
    </ci:Field>

    <!-- Date/time for Once -->
    <StackPanel x:Name="OncePanel" Spacing="8">
      <ci:Field Label="日期">
        <CalendarDatePicker x:Name="OnceDatePicker" />
      </ci:Field>
      <ci:Field Label="时间">
        <TimePicker x:Name="OnceTimeBox" />
      </ci:Field>
    </StackPanel>

    <!-- Daily -->
    <StackPanel x:Name="DailyPanel" Spacing="8" IsVisible="False">
      <ci:Field Label="时间"><TimePicker x:Name="DailyTimeBox"/></ci:Field>
      <ci:Field Label="开始日期 (可选)"><CalendarDatePicker x:Name="DailyStartDate"/></ci:Field>
      <ci:Field Label="结束日期 (可选)"><CalendarDatePicker x:Name="DailyEndDate"/></ci:Field>
    </StackPanel>

    <!-- Weekly -->
    <StackPanel x:Name="WeeklyPanel" Spacing="8" IsVisible="False">
      <ci:Field Label="时间"><TimePicker x:Name="WeeklyTimeBox"/></ci:Field>
      <ci:Field Label="重复星期">
        <WrapPanel>
          <CheckBox x:Name="ChkSun" Content="日"/>
          <CheckBox x:Name="ChkMon" Content="一"/>
          <CheckBox x:Name="ChkTue" Content="二"/>
          <CheckBox x:Name="ChkWed" Content="三"/>
          <CheckBox x:Name="ChkThu" Content="四"/>
          <CheckBox x:Name="ChkFri" Content="五"/>
          <CheckBox x:Name="ChkSat" Content="六"/>
        </WrapPanel>
      </ci:Field>
      <ci:Field Label="开始日期 (可选)"><CalendarDatePicker x:Name="WeeklyStartDate"/></ci:Field>
      <ci:Field Label="结束日期 (可选)"><CalendarDatePicker x:Name="WeeklyEndDate"/></ci:Field>
    </StackPanel>

    <!-- Yearly -->
    <StackPanel x:Name="YearlyPanel" Spacing="8" IsVisible="False">
      <ci:Field Label="时间"><TimePicker x:Name="YearlyTimeBox"/></ci:Field>
      <ci:Field Label="月份">
        <ComboBox x:Name="YearMonthCombo">
          <ComboBoxItem>1</ComboBoxItem>
          <ComboBoxItem>2</ComboBoxItem>
          <ComboBoxItem>3</ComboBoxItem>
          <ComboBoxItem>4</ComboBoxItem>
          <ComboBoxItem>5</ComboBoxItem>
          <ComboBoxItem>6</ComboBoxItem>
          <ComboBoxItem>7</ComboBoxItem>
          <ComboBoxItem>8</ComboBoxItem>
          <ComboBoxItem>9</ComboBoxItem>
          <ComboBoxItem>10</ComboBoxItem>
          <ComboBoxItem>11</ComboBoxItem>
          <ComboBoxItem>12</ComboBoxItem>
        </ComboBox>
      </ci:Field>
      <ci:Field Label="日">
        <TextBox x:Name="YearDayBox" />
      </ci:Field>
      <ci:Field Label="开始日期 (可选)"><CalendarDatePicker x:Name="YearlyStartDate"/></ci:Field>
      <ci:Field Label="结束日期 (可选)"><CalendarDatePicker x:Name="YearlyEndDate"/></ci:Field>
    </StackPanel>

    <!-- 自动化行动 -->
    <Separator Margin="0 8 0 4" />
    <ci:Field Label="关联行动（触发提醒时自动执行）">
      <automation:ActionControl x:Name="ActionSetEditor" />
    </ci:Field>
  </StackPanel>
</UserControl>
