<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             xmlns:views="clr-namespace:ClassIsland.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ClassIsland.Views.DataTransferPage">
    <UserControl.Styles>
        <Style Selector="CheckBox">
            <Setter Property="Padding" Value="8 0"/>
        </Style>
    </UserControl.Styles>
    <ScrollViewer DataContext="{Binding RelativeSource={RelativeSource AncestorType=views:DataTransferPage}}"
                  Classes.export="{Binding ViewModel.IsExport}">
        <Grid MaxWidth="600" 
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Center">
            
            <Carousel Width="600" SelectedIndex="{Binding ViewModel.PageIndex}"
                      VerticalAlignment="Stretch"
                      ClipToBounds="False">
                <Carousel.Items>
                    <Border VerticalAlignment="Center">
                        <StackPanel>   
                            <TextBlock Text="数据迁移" HorizontalAlignment="Center"
                                       Margin="0 0 0 4"
                                       Theme="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock Text="向 ClassIsland 导入或从 ClassIsland 导出数据。"
                                       HorizontalAlignment="Center"
                                       Margin="0 0 0 8" />
                            <TabControl Classes="compact">
                                <TabItem Header="导入">
                                    <StackPanel Classes="animated-intro" Spacing="2">
                                        <controls:SettingsExpander Header="ClassIsland 2.x"
                                                                   IsClickEnabled="True"
                                                                   Click="SettingsExpanderImportFromClassIsland2_OnClick">
                                            <controls:SettingsExpander.IconSource>
                                                <controls:BitmapIconSource
                                                    UriSource="avares://ClassIsland/Assets/AppLogo.png" />
                                            </controls:SettingsExpander.IconSource>
                                        </controls:SettingsExpander>
                                        <controls:SettingsExpander Header="ClassIsland 1.7.0.x"
                                                                   IsClickEnabled="True"
                                                                   Click="SettingsExpanderImportFromClassIsland1_OnClick">
                                            <controls:SettingsExpander.IconSource>
                                                <controls:BitmapIconSource
                                                    UriSource="avares://ClassIsland/Assets/AppLogo.png" />
                                            </controls:SettingsExpander.IconSource>
                                        </controls:SettingsExpander>
                                        <controls:SettingsExpander Header="Class Widgets 1.2"
                                                                   IsClickEnabled="True"
                                                                   Click="ImportFromClassWidgets1_OnClick"
                                                                   IconSource="{ci:FluentIconSource &#xe06f;}" />
                                    </StackPanel>
                                </TabItem>
                                <TabItem Header="导出">
                                    <StackPanel Classes="animated-intro" Spacing="2">
                                        <controls:InfoBar Message="此处的数据导出功能主要用于在不同 ClassIsland 实例间转移数据。若需导出诊断信息，请前往【应用设置】->【更多选项…】->【导出诊断数据】；若需备份应用数据，请使用【应用设置】->【通用】->【存储】中的备份功能。"
                                                          IsOpen="True" IsClosable="False"/>
                                        <controls:SettingsExpander Header="ClassIsland 2.x"
                                                                   IsClickEnabled="True"
                                                                   Click="SettingsExpanderExportToClassIsland2_OnClick">
                                            <controls:SettingsExpander.IconSource>
                                                <controls:BitmapIconSource
                                                    UriSource="avares://ClassIsland/Assets/AppLogo.png" />
                                            </controls:SettingsExpander.IconSource>
                                        </controls:SettingsExpander>
                                    </StackPanel>
                                </TabItem>
                            </TabControl>
                        </StackPanel>
                    </Border>
                    <Border VerticalAlignment="Center">
                        <StackPanel Classes="animated-intro" Spacing="2" VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       Margin="0 0 0 4"
                                       Theme="{StaticResource SubtitleTextBlockStyle}">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock">
                                        <Setter Property="Text" Value="选择要导入的数据"/>
                                    </Style>
                                    <Style Selector=".export TextBlock">
                                        <Setter Property="Text" Value="选择要导出的数据"/>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                            <TextBlock Text="{Binding ViewModel.ImportDescription}" 
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0 0 0 4"/>
                            <TextBlock HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0 0 0 8">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock">
                                        <Setter Property="Text" Value="选择要导入的信息"/>
                                    </Style>
                                    <Style Selector=".export TextBlock">
                                        <Setter Property="Text" Value="选择要导出的信息"/>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                            <CheckBox IsChecked="{Binding ViewModel.IsProfileSelected}">
                                <ci:Thing IconSource="{ci:FluentIconSource &#xe699;}"
                                          VerticalAlignment="Center"
                                          Header="课表配置"
                                          Description="包括课表内容、时间安排、科目定义等信息。"/>
                            </CheckBox>
                            <CheckBox IsChecked="{Binding ViewModel.IsSettingsSelected}">
                                <ci:Thing IconSource="{ci:FluentIconSource &#xef27;}"
                                          Header="应用设置"
                                          VerticalAlignment="Center"
                                          Description="包括应用的各个首选项，如隐藏设置、颜色设置、提醒/铃声设置、天气信息等。"/>
                            </CheckBox>
                            <CheckBox IsChecked="{Binding ViewModel.IsOtherConfigSelected}">
                                <ci:Thing IconSource="{ci:FluentIconSource &#xe06f;}"
                                          Header="其它配置"
                                          VerticalAlignment="Center"
                                          Description="组件、自动化等配置文件。"/>
                            </CheckBox>
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <Button Click="ButtonTurnBack_OnClick"
                                        ToolTip.Tip="上一步"
                                        Content="{ci:FluentIcon &#xE108;, FontSize=18}"
                                        Width="48" Height="48"
                                        CornerRadius="24"
                                        Margin="0 8 0 0"/>
                                <Button Click="ButtonNext_OnClick"
                                        ToolTip.Tip="下一步"
                                        Content="{ci:FluentIcon &#xE130;, FontSize=18}"
                                        Width="48" Height="48"
                                        CornerRadius="24"
                                        Classes="accent" 
                                        Margin="0 8 0 0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border VerticalAlignment="Center">
                        <StackPanel Classes="animated-intro" Spacing="2" VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       Margin="0 0 0 4"
                                       Theme="{StaticResource SubtitleTextBlockStyle}">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock">
                                        <Setter Property="Text" Value="导入来源"/>
                                    </Style>
                                    <Style Selector=".export TextBlock">
                                        <Setter Property="Text" Value="导出目标"/>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0 0 0 8">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock">
                                        <Setter Property="Text" Value="选择要导入的数据来源。"/>
                                    </Style>
                                    <Style Selector=".export TextBlock">
                                        <Setter Property="Text" Value="选择要导出到的目标。"/>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>

                            <controls:SettingsExpander Header="浏览…"
                                                       IconSource="{ci:FluentIconSource &#xe88d;}"
                                                       IsClickEnabled="True"
                                                       Click="SettingsExpanderBrowse_OnClick">
                                <controls:SettingsExpander.Styles>
                                    <Style Selector="controls|SettingsExpander">
                                        <Setter Property="Description" Value="手动浏览导入位置"/>
                                    </Style>
                                    <Style Selector=".export controls|SettingsExpander">
                                        <Setter Property="Description" Value="手动浏览导出位置"/>
                                    </Style>
                                </controls:SettingsExpander.Styles>
                            </controls:SettingsExpander>
                            <Button Click="ButtonTurnBack_OnClick"
                                    ToolTip.Tip="上一步"
                                    Content="{ci:FluentIcon &#xE108;, FontSize=18}"
                                    Width="48" Height="48"
                                    CornerRadius="24"
                                    HorizontalAlignment="Center"
                                    Margin="0 8 0 0"/>
                        </StackPanel>
                    </Border>
                    <Border VerticalAlignment="Center">
                        <StackPanel Classes="animated-intro" Spacing="2" VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       Margin="0 0 0 4"
                                       Theme="{StaticResource SubtitleTextBlockStyle}">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock">
                                        <Setter Property="Text" Value="正在导入"/>
                                    </Style>
                                    <Style Selector=".export TextBlock">
                                        <Setter Property="Text" Value="正在导出"/>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                            <TextBlock
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Margin="0 0 0 4">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock">
                                        <Setter Property="Text" Value="请坐和放宽，导入很快就能完成。"/>
                                    </Style>
                                    <Style Selector=".export TextBlock">
                                        <Setter Property="Text" Value="请坐和放宽，导出很快就能完成。"/>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                            <controls:ProgressRing IsIndeterminate="True"
                                                   Width="48" Height="48"
                                                   Margin="0 8 0 0"/>
                        </StackPanel>
                    </Border>
                    <Border VerticalAlignment="Center">
                        <StackPanel Classes="animated-intro" Spacing="2" VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       Margin="0 0 0 4"
                                       Theme="{StaticResource SubtitleTextBlockStyle}">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock">
                                        <Setter Property="Text" Value="导入完成"/>
                                    </Style>
                                    <Style Selector=".export TextBlock">
                                        <Setter Property="Text" Value="导出完成"/>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0 0 0 4">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock">
                                        <Setter Property="Text" Value="已成功完成导入。"/>
                                    </Style>
                                    <Style Selector=".export TextBlock">
                                        <Setter Property="Text" Value="已成功完成导出。"/>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                            <Button ToolTip.Tip="完成"
                                    VerticalAlignment="Center"
                                    Content="{ci:FluentIcon &#xE423;, FontSize=18}"
                                    Width="48" Height="48"
                                    CornerRadius="24"
                                    Classes="accent" 
                                    HorizontalAlignment="Center"
                                    Click="ButtonFinish_OnClick"
                                    Margin="0 8 0 0"/>
                        </StackPanel>
                    </Border>
                </Carousel.Items>
                <Carousel.PageTransition>
                    <CompositePageTransition>
                        <PageSlide Duration="0:0:0.3" Orientation="Horizontal"
                                   SlideOutEasing="0.76, 0, 0.24, 1"
                                   SlideInEasing="0.76, 0, 0.24, 1"/>
                        <CrossFade Duration="0:0:0.3"/>
                    </CompositePageTransition>
                </Carousel.PageTransition>
            </Carousel>
        </Grid>
    </ScrollViewer>
</UserControl>
