<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             xmlns:views="clr-namespace:ClassIsland.Views"
             xmlns:welcomePages="clr-namespace:ClassIsland.Views.WelcomePages"
             xmlns:demo="clr-namespace:ClassIsland.Controls.Demo"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ClassIsland.Views.WelcomePages.ColorThemePage">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                Classes="settings-container animated-intro"
                DataContext="{Binding RelativeSource={RelativeSource AncestorType=welcomePages:ColorThemePage}}"
                MaxWidth="600">
        <TextBlock Text="颜色主题" HorizontalAlignment="Center"
                   Margin="0 0 0 4"
                   Theme="{StaticResource SubtitleTextBlockStyle}"/>
        <TextBlock Text="设置 ClassIsland 的主题外观。" HorizontalAlignment="Center"
                   Margin="0 0 0 8"/>
        
        <ListBox SelectedIndex="{Binding ViewModel.SettingsService.Settings.Theme}" HorizontalAlignment="Center">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBoxItem>
                <StackPanel Margin="0 8 0 4">
                    <Panel>
                        <ThemeVariantScope RequestedThemeVariant="Dark">
                            <ThemeVariantScope.Clip>
                                <RectangleGeometry Rect="0 0 40 75"/>
                            </ThemeVariantScope.Clip>
                            <demo:ThemeDemo Width="80" />
                        </ThemeVariantScope>
                        <ThemeVariantScope RequestedThemeVariant="Light">
                            <ThemeVariantScope.Clip>
                                <RectangleGeometry Rect="40 0 40 75"/>
                            </ThemeVariantScope.Clip>
                            <demo:ThemeDemo Width="80" />
                        </ThemeVariantScope>
                    </Panel>
                    <RadioButton Content="跟随系统" IsChecked="{Binding $parent[ListBoxItem].IsSelected}"/>
                </StackPanel>
            </ListBoxItem>
            <ListBoxItem>
                <StackPanel Margin="0 8 0 4">
                    <ThemeVariantScope RequestedThemeVariant="Light">
                        <demo:ThemeDemo Width="80" />
                    </ThemeVariantScope>
                    <RadioButton Content="明亮" IsChecked="{Binding $parent[ListBoxItem].IsSelected}"/>
                </StackPanel>
            </ListBoxItem>
            <ListBoxItem>
                <StackPanel Margin="0 8 0 4">
                    <ThemeVariantScope RequestedThemeVariant="Dark">
                        <demo:ThemeDemo Width="80" />
                    </ThemeVariantScope>
                    <RadioButton Content="黑暗" IsChecked="{Binding $parent[ListBoxItem].IsSelected}"/>
                </StackPanel>
            </ListBoxItem>
                    <ListBoxItem>
                <StackPanel Margin="0 8 0 4">
                    <Panel>
                        <ThemeVariantScope RequestedThemeVariant="Dark">
                            <ThemeVariantScope.Clip>
                                <RectangleGeometry Rect="0 0 40 75"/>
                            </ThemeVariantScope.Clip>
                            <demo:ThemeDemo Width="80" />
                        </ThemeVariantScope>
                        <ThemeVariantScope RequestedThemeVariant="Light">
                            <ThemeVariantScope.Clip>
                                <RectangleGeometry Rect="40 0 40 75"/>
                            </ThemeVariantScope.Clip>
                            <demo:ThemeDemo Width="80" />
                        </ThemeVariantScope>
                        <Canvas Width="80" Height="75" HorizontalAlignment="Right">
                            <Ellipse Canvas.Left="54" Canvas.Top="4" Width="10" Height="10" Fill="#FFB74D" Stroke="#FF9800" StrokeThickness="1"/>
                            <Line Canvas.Left="59" Canvas.Top="1" X1="0" Y1="0" X2="0" Y2="2" Stroke="#FF9800" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Line Canvas.Left="59" Canvas.Top="15" X1="0" Y1="0" X2="0" Y2="2" Stroke="#FF9800" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Line Canvas.Left="52" Canvas.Top="4" X1="0" Y1="0" X2="-2" Y2="0" Stroke="#FF9800" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Line Canvas.Left="66" Canvas.Top="4" X1="0" Y1="0" X2="2" Y2="0" Stroke="#FF9800" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Panel>
                    <RadioButton Content="跟随日出日落" IsChecked="{Binding $parent[ListBoxItem].IsSelected}"/>
                </StackPanel>
            </ListBoxItem>
        </ListBox>
        
        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
            <Button Command="{x:Static views:WelcomeWindow.WelcomeNavigateBackCommand}"
                    ToolTip.Tip="上一步"
                    Content="{ci:FluentIcon &#xE108;, FontSize=18}"
                    Width="48" Height="48"
                    CornerRadius="24"
                    Margin="0 8 0 0"/>
            <Button Command="{x:Static views:WelcomeWindow.WelcomeNavigateForwardCommand}"
                    ToolTip.Tip="下一步"
                    Content="{ci:FluentIcon &#xE130;, FontSize=18}"
                    Width="48" Height="48"
                    CornerRadius="24"
                    Classes="accent" 
                    Margin="0 8 0 0"/>
        </StackPanel>
    </StackPanel>
</UserControl>
