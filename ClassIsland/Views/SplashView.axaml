<ci:ViewBase xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             xmlns:classIsland="clr-namespace:ClassIsland"
             xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ClassIsland.Views.SplashView"
             NavigationPage.HasNavigationBar="False"
             Header="">
    <Grid>
        <StackPanel Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Classes="items-halign-center">
            <Image Source="/Assets/AppLogo.png" Width="72" Height="72"/>
            <controls:FAProgressRing Width="24" Height="24"/>
        </StackPanel>
        
        <TextBlock FontSize="12" Classes="l-instructive" Margin="0 0 0 2"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center">
            <Run Text="{x:Static classIsland:App.AppVersion}"/>-<Run Text="{x:Static classIsland:App.AppCodeName}"/>
        </TextBlock>
    </Grid>
</ci:ViewBase>
